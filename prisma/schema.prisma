generator client {
  provider = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(cuid())
  category  String
  title     String
  client    String
  location  String
  date      String
  img       String
  desc      String
  specs     String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
